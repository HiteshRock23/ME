# =============================================================================
# ME — Environment Variables
# =============================================================================
# Copy this file to .env and update values for your local setup.

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=me_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# AI — LLM Configuration
# -----------------------------------------------------------------------------
# API key for the LLM provider (required for AI features)
AI_API=your-api-key-here

# Optional overrides (defaults shown):
# AI_BASE_URL=https://integrate.api.nvidia.com/v1
# AI_MODEL=z-ai/glm-5.2
# AI_MAX_RETRIES=3
# AI_TIMEOUT=30

# -----------------------------------------------------------------------------
# Supermemory Local (Memory Engine)
# -----------------------------------------------------------------------------
# Base URL for the local Supermemory instance
SUPERMEMORY_URL=http://localhost:6767

# Local bearer API key generated during installation
SUPERMEMORY_API_KEY=sm_your_local_key_here

# Timeout in seconds for HTTP requests to Supermemory
SUPERMEMORY_TIMEOUT=10


# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
